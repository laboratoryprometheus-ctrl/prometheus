<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Black Page with Left Header and Videos</title>
    <style>
        /* Base styles */
        body {
            background-color: #000000;
            color: #ffffff;
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px; /* Adds a clean border space around the content */
        }

        /* Forces layout alignment to the left */
        .header-container {
            display: flex;
            justify-content: flex-start; /* Aligns content to the absolute left */
            margin-bottom: 30px;
        }

        /* Sets the size of the header image */
        .header-image {
            max-width: 300px; /* Limits the size so it does not fill the screen */
            width: 100%;      /* Allows it to shrink nicely on small screens */
            height: auto;
            display: block;
        }

        /* Layout for the side-by-side videos */
        .video-container {
            display: flex;
            justify-content: flex-start; /* Aligns videos to the left */
            gap: 20px;
            flex-wrap: wrap; 
        }

        /* Defines video dimensions */
        .video-box {
            flex: 0 1 45%; /* Keeps them side-by-side up to 45% width each */
            max-width: 600px;
            min-width: 300px; /* Prevents them from getting too squished */
        }

        .video-box iframe {
            width: 100%;
            height: 315px;
            border: none;
        }

        /* Mobile adjustments: stacks elements on tiny screens */
        @media (max-width: 600px) {
            .video-container {
                flex-direction: column;
            }
            .video-box {
                flex: 1 1 100%;
            }
        }
    </style>
</head>
<body>

    <!-- Header Image Section (Aligned Left) -->
    <div class="header-container">
        <img src="https://64.media.tumblr.com/072796e3554f44a1fdc670da87ddcc11/678c256390decf6b-fc/s640x960/0e841d8595c598b84f40540b4cd21452162ed9e9.pnj" alt="Website Header" class="header-image">
    </div>

    <!-- Video Section (Aligned Left, Side-by-Side) -->
    <div class="video-container">
        <div class="video-box">
            <iframe src="https://youtube.com" allowfullscreen></iframe>
        </div>
        <div class="video-box">
            <iframe src="https://youtube.com" allowfullscreen></iframe>
        </div>
    </div>

</body>
</html>
